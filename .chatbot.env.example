# ===== CHATBOT LLM — pick ONE with PROVIDER; read live from this file =====
PROVIDER=OPENROUTER          # OPENAI | AZURE_OPENAI | OPENROUTER | LOCAL

# --- OpenRouter (default). ENDPOINT: not needed. Reuses OPENROUTER_API_KEY from .ocr.env
#     (set one here only if the chatbot needs a DIFFERENT key than OCR). ---
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_API_KEY=

# --- OpenAI (PROVIDER=OPENAI). ENDPOINT: not needed ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Azure OpenAI (PROVIDER=AZURE_OPENAI). ENDPOINT: REQUIRED ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=                    # e.g. https://your-resource.openai.azure.com
AZURE_OPENAI_MODEL=                       # your deployment name
AZURE_OPENAI_API_VERSION=2024-06-01

# --- Local LLM: Ollama / LM Studio / llama.cpp (PROVIDER=LOCAL). ENDPOINT: base URL ---
LOCAL_LLM_ENDPOINT=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.1
LOCAL_LLM_API_KEY=

# ===== Watcher API server secrets =====
WATCHER_JWT_SECRET=                       # empty -> insecure built-in dev secret (localhost only)
WATCHER_API_TOKEN=                        # required only when server.require_api_token: true
