# Rename this file to .env and fill in your values.
# Get a FREE OCR API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_api_key_here

# (Optional) override the OCR model. Default: qwen/qwen3-vl-30b-a3b-instruct
# Other options:
#   qwen/qwen3-vl-235b-a22b-instruct   (strongest, slower)
#   qwen/qwen3-vl-8b-instruct          (lightest, fastest)
# OCR_MODEL=qwen/qwen3-vl-30b-a3b-instruct

# SMTP password used to send alert emails. This variable name must match
# `password_env` in config/rules.yaml. Leave empty if running in DRY-RUN.
#   - Gmail: use a 16-char "App Password" (not your normal login password).
#   - Office 365 / Outlook (e.g. you@company.com): your mailbox password, or an
#     app password if MFA is enabled. SMTP AUTH must be allowed by your org.
WATCHER_SMTP_PASSWORD=
