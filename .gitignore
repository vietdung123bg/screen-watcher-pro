# ===== Secrets & environment variables (NEVER commit) =====
.env
.env.*
!.env.example
# Split env files (real ones hold secrets; *.example are safe to commit)
.ocr.env
.smtp.env
.chatbot.env

# ===== Python =====
.venv/
venv/
__pycache__/
*.pyc

# ===== App data: screenshots, OCR text, SQLite DB, logs =====
data/screenshots/
data/ocr_results/
data/*.db
logs/

# ===== DB backups (e.g. auto-created by the UUID migration) =====
*.bak
data/*.bak
*.pre-uuid.bak

# ===== Claude Code local tooling / session state =====
.claude/

# ===== Local config with real credentials / personal emails =====
# Copy config/rules.example.yaml -> config/rules.yaml and fill in your own values.
config/rules.yaml
# Stray top-level rules.yaml is not used by the app (it reads config/rules.yaml).
/rules.yaml

# ===== Jupyter =====
.ipynb_checkpoints/

# ===== IDE / OS noise =====
.vscode/
.idea/
.DS_Store
Thumbs.db

# ===== Workshop demo artifacts =====
workshop/demo_data/
workshop/*.pdf
